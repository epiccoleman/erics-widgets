{
  "multipart": [
    { "when": { "facing": "up" },    "apply": { "model": "erics-widgets:block/splitter_input" } },
    { "when": { "facing": "down" },  "apply": { "model": "erics-widgets:block/splitter_input", "x": 180 } },
    { "when": { "facing": "north" }, "apply": { "model": "erics-widgets:block/splitter_input", "x": 90 } },
    { "when": { "facing": "south" }, "apply": { "model": "erics-widgets:block/splitter_input", "x": 270 } },
    { "when": { "facing": "east" },  "apply": { "model": "erics-widgets:block/splitter_input", "x": 90, "y": 90 } },
    { "when": { "facing": "west" },  "apply": { "model": "erics-widgets:block/splitter_input", "x": 90, "y": 270 } },

    { "when": { "facing": "up" }, "apply": { "model": "erics-widgets:block/splitter_output" } },
    { "when": { "facing": "up" }, "apply": { "model": "erics-widgets:block/splitter_output", "y": 180 } },
    { "when": { "facing": "up" }, "apply": { "model": "erics-widgets:block/splitter_output", "y": 90 } },
    { "when": { "facing": "up" }, "apply": { "model": "erics-widgets:block/splitter_output", "y": 270 } },

    { "when": { "facing": "down" }, "apply": { "model": "erics-widgets:block/splitter_output" } },
    { "when": { "facing": "down" }, "apply": { "model": "erics-widgets:block/splitter_output", "y": 180 } },
    { "when": { "facing": "down" }, "apply": { "model": "erics-widgets:block/splitter_output", "y": 90 } },
    { "when": { "facing": "down" }, "apply": { "model": "erics-widgets:block/splitter_output", "y": 270 } },

    { "when": { "facing": "north" }, "apply": { "model": "erics-widgets:block/splitter_output", "y": 90 } },
    { "when": { "facing": "north" }, "apply": { "model": "erics-widgets:block/splitter_output", "y": 270 } },
    { "when": { "facing": "north" }, "apply": { "model": "erics-widgets:block/splitter_output", "x": 270 } },
    { "when": { "facing": "north" }, "apply": { "model": "erics-widgets:block/splitter_output", "x": 90 } },

    { "when": { "facing": "south" }, "apply": { "model": "erics-widgets:block/splitter_output", "y": 90 } },
    { "when": { "facing": "south" }, "apply": { "model": "erics-widgets:block/splitter_output", "y": 270 } },
    { "when": { "facing": "south" }, "apply": { "model": "erics-widgets:block/splitter_output", "x": 270 } },
    { "when": { "facing": "south" }, "apply": { "model": "erics-widgets:block/splitter_output", "x": 90 } },

    { "when": { "facing": "east" }, "apply": { "model": "erics-widgets:block/splitter_output" } },
    { "when": { "facing": "east" }, "apply": { "model": "erics-widgets:block/splitter_output", "y": 180 } },
    { "when": { "facing": "east" }, "apply": { "model": "erics-widgets:block/splitter_output", "x": 270 } },
    { "when": { "facing": "east" }, "apply": { "model": "erics-widgets:block/splitter_output", "x": 90 } },

    { "when": { "facing": "west" }, "apply": { "model": "erics-widgets:block/splitter_output" } },
    { "when": { "facing": "west" }, "apply": { "model": "erics-widgets:block/splitter_output", "y": 180 } },
    { "when": { "facing": "west" }, "apply": { "model": "erics-widgets:block/splitter_output", "x": 270 } },
    { "when": { "facing": "west" }, "apply": { "model": "erics-widgets:block/splitter_output", "x": 90 } }
  ]
}
